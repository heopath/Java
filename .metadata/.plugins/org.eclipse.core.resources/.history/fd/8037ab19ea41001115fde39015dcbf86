public class VariableTest {
	public static void main(String[] args) {
		
		// 변수(Varialbe)
		int a = 1; // 선언
		int b = 3;
		
		System.out.println("a : " + a);
		System.out.println("b : " + b);
		
		a = 4;
		b = 7;
		
		System.out.println("a : " + a);
		System.out.println("b : " + b);
		
	}
}
