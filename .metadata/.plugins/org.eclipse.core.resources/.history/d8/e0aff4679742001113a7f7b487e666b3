public class WhileTest {
	public static void main(String[] args) {
		
		//while 기본
		
		int i = 0;
		while(i < 10) {
			System.out.println("i : " + i);
			i++;
		}
		
		// 1부터 10까지 합
		int sum = 0, k = 1;
		
		while( k <= 10) {
			sum+=k;
		}
		System.out.println("1부터 10까지 합 : " + sum);
	}
}
