public class WhileTest {
	public static void main(String[] args) {
		
		//while 기본
		
		/*
		 * int i = 0; while(i < 10) { System.out.println("i : " + i); i++; }
		 */
		
		// 1부터 10까지 합
		int sum = 0, k = 1;
		
		while( k <= 10) {
			sum+=k;
			k++;
		}
		System.out.println("1부터 10까지 합 : " + sum);
		
		// do-while
		int total = 0, j = 1;
		do {
			if(j % 2 == 0) {
				total += j;
			}
			
			j++;
			
		}while(j <= 10);
		
		System.out.println("1부터 10까지 짝수합 : " + total);
	}
}
