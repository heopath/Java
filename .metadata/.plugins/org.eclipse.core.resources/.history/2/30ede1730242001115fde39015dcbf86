public class IfTest {
	public static void main(String[] args) {
		//if
		int num1 = 1;
		int num2 = 2;
		
		if(num1 < num2) {
			// 조건이 참일때
			System.out.println("num1은 num2 보다 작다");
		}
		
		if(num1 > 1) {
			// 조건이 거짓일때
			System.out.println("num1은 1보다 크다.");
		}
		
		if(num1 > 0) {
			if(num2 > 1) {
				System.out.println("num1은 0보다 크고 num2는 1보다 크다.");
			}
		}
		
		//if ~ else
		
		//if ~ else if ~ else
		
	}
}
