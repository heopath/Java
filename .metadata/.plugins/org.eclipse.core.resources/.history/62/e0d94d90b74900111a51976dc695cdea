package class1.sub5;

public class Student {
	private String name;
	private String studentId;
	private Subject[] subjects;
	private int[] scores;
	private int subjectCount;
	
	public Student(String name, String studentId) {
		this.name = name;
		this.studentId = studentId;
		this.subjects = new Subject[10];
		this.scores = new int[10];
		this.subjectCount = 0;
	}
	
	public void enrollSubject(Subject subjects) {
		this.subjectCount += 1;
		this.subjects[this.subjectCount] = subjects;	
	}
	
	public void setScore(Subject subject, int scores) {
		this.subjectCount += 1;
		this.scores[this.subjectCount] = scores;
	}
	
	public void printStudentInfo() {
		System.out.println("이름 : " + this.name);
		System.out.println("ID : " + this.studentId);
		System.out.println("수강 과목 및 성적 : " + this.subjects);
		System.out.println(this.scores);
	}
	
	public String getName() {
		return this.name;
	}
}
