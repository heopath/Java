// 외부 클래스
class Outer {
	
	private int x;
		public Outer(int x) {
		this.x = x;
	}
	
	public void show() {
		System.out.println("Outer x : " + x);
	}
	
	// 내부 클래스
	class Inner {
		private int x;
		
		public Inner(int x) {
			this.x = x;
		}
		
		public void show() {
			System.out.println("Inner x : " + x);
		}
	}
	
}

