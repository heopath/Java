package test1;
public class Test03 {
	public static void main(String[] args) {
		
		int result = 1;
		int num = 0;
		
		result = num++;
		System.out.println("result : "+result);
		result = ++num;
		System.out.println("result : "+result);
		result = num--;
		System.out.println("result : "+result);
		result = --num;
		System.out.println("result : "+result);
	}
}