public class MethodTest {
	// main 메서드 : Java 프로그램 시작함수
	public static void main(String[] args) {
		
		// 메서드 호출(call)
		int x = 1;
		int y;
		y = f(x);
		System.out.println(y);
	} // main end
	
	// 메서드 정의(Define)
	public static int f(int x) { // 반환타임, 메서드명, 매개변수
		
		int y = 2 * x + 3;
		return  y;
	}
}
